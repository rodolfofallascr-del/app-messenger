{
  "expo": {
    "name": "Chat Santanita",
    "slug": "app-mesajeria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/chat-santanita-icon-square.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/chat-santanita-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/chat-santanita-icon-square.png",
        "backgroundColor": "#020617"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/chat-santanita-icon-square.png"
    }
  }
}
